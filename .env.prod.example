# Copiez ce fichier en .env.prod sur le VPS et remplacez les secrets.

# Chemin public servi par le Caddy du portfolio.
PUBLIC_ORIGIN=https://quentin-bouchot.fr
PUBLIC_BASE_PATH=/projets/TradeCopilot/

# Client React/Vite. Ces valeurs sont lues au build du conteneur client.
VITE_APP_BASE_PATH=/projets/TradeCopilot/
VITE_API_BASE_URL=/projets/TradeCopilot
VITE_AUTH_AUTHORITY=https://quentin-bouchot.fr/projets/TradeCopilot/auth/realms/tradecopilot
VITE_AUTH_CLIENT_ID=tradecopilot-client
VITE_AUTH_SCOPE=openid profile email

# API ASP.NET Core. L'issuer public reste en HTTPS.
AUTH_AUTHORITY=https://quentin-bouchot.fr/projets/TradeCopilot/auth/realms/tradecopilot
AUTH_METADATA_ADDRESS=http://keycloak:8080/auth/realms/tradecopilot/.well-known/openid-configuration
AUTH_BACKCHANNEL_AUTHORITY=http://keycloak:8080/auth/realms/tradecopilot
AUTH_AUDIENCE=tradecopilot-api
# false car l'API lit la metadata Keycloak via le reseau Docker interne en HTTP.
# Le trafic public reste protege par le HTTPS du Caddy du portfolio.
AUTH_REQUIRE_HTTPS_METADATA=false

# Keycloak public, derriere Caddy.
KEYCLOAK_HOSTNAME=https://quentin-bouchot.fr/projets/TradeCopilot/auth
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change-this-keycloak-admin-password
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-this-keycloak-db-password

# Base applicative TradeCopilot.
TRADECOPILOT_DB_NAME=tradecopilot
TRADECOPILOT_DB_USER=tradecopilot
TRADECOPILOT_DB_PASSWORD=change-this-tradecopilot-db-password
