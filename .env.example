# Copiez ce fichier en .env sur le VPS et remplacez toutes les valeurs sensibles.

KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change-this-admin-password
KEYCLOAK_DB_PASSWORD=change-this-database-password

# Local Docker par defaut.
KEYCLOAK_HOSTNAME=http://localhost/auth
AUTH_AUTHORITY=http://localhost/auth/realms/tradecopilot
AUTH_METADATA_ADDRESS=http://keycloak:8080/auth/realms/tradecopilot/.well-known/openid-configuration
AUTH_BACKCHANNEL_AUTHORITY=http://keycloak:8080/auth/realms/tradecopilot
AUTH_AUDIENCE=tradecopilot-api
AUTH_REQUIRE_HTTPS_METADATA=false
VITE_AUTH_AUTHORITY=http://localhost/auth/realms/tradecopilot
VITE_AUTH_CLIENT_ID=tradecopilot-client
VITE_AUTH_SCOPE=openid profile email

# Exemple VPS HTTPS :
# KEYCLOAK_HOSTNAME=https://tradecopilot.example.com/auth
# AUTH_AUTHORITY=https://tradecopilot.example.com/auth/realms/tradecopilot
# AUTH_METADATA_ADDRESS=http://keycloak:8080/auth/realms/tradecopilot/.well-known/openid-configuration
# AUTH_BACKCHANNEL_AUTHORITY=http://keycloak:8080/auth/realms/tradecopilot
# AUTH_REQUIRE_HTTPS_METADATA=false
# VITE_AUTH_AUTHORITY=https://tradecopilot.example.com/auth/realms/tradecopilot
